# --- Public site ---
NEXT_PUBLIC_SITE_URL=https://eiosh.com
NEXT_PUBLIC_WHATSAPP_NUMBER=+923001234567
NEXT_PUBLIC_CONTACT_EMAIL=info@eiosh.com
NEXT_PUBLIC_CONTACT_PHONE=+92 300 1234567

# --- CMS (choose one) ---
# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=

# Strapi (alternative)
NEXT_PUBLIC_STRAPI_URL=
STRAPI_API_TOKEN=

# --- Inquiry / newsletter delivery ---
INQUIRY_WEBHOOK_URL=
NEWSLETTER_PROVIDER=mailchimp
NEWSLETTER_API_KEY=

# --- Analytics ---
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=

# --- Built-in CMS (/admin) ---
# Required in production. Dev default is "eiosh-admin".
ADMIN_PASSWORD=

# --- Companion PHP modules (served by XAMPP Apache locally) ---
NEXT_PUBLIC_LMS_URL=
NEXT_PUBLIC_EXAM_URL=
NEXT_PUBLIC_INVOICE_URL=

# --- AI assistant (chat FAB + CMS generate buttons) ---
# Providers with free tiers:
#   groq         — Llama 3 / Mixtral, fast, generous free tier
#   openrouter   — models tagged ":free" available without payment
#   huggingface  — Inference API free with rate limits
#   openai       — standard, paid key required
#   ollama       — run locally (http://localhost:11434), no key needed
#   mock         — offline demo (default) — returns scripted answers
AI_PROVIDER=mock
AI_API_KEY=
# AI_MODEL=
# AI_BASE_URL=
